[Unit]
Description=Neko Tunneling
Documentation=https://github.com/xenvoid404/nekotun
After=network.target nss-lookup.target

[Service]
User=root
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
NoNewPrivileges=true
WorkingDirectory=/etc/nekotun
ExecStart=/usr/local/bin/nekotun
Restart=on-failure
RestartPreventExitStatus=23
RestartSec=3
LimitNOFILE=1048576
LimitNPROC=512

[Install]
WantedBy=multi-user.target
